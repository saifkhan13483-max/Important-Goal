rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Admin check: UIDs stored in config/admins document under a 'uids' array
    function isAdmin() {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/config/admins).data.uids;
    }

    // Returns the workspaceId stored on the requesting user's profile
    function myWorkspaceId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.workspaceId;
    }

    // Returns the workspaceId stored on a target user's profile
    function targetWorkspaceId(targetUserId) {
      return get(/databases/$(database)/documents/users/$(targetUserId)).data.workspaceId;
    }

    // True when the requesting user shares a workspace with targetUserId
    function inSameWorkspace(targetUserId) {
      let mine = myWorkspaceId();
      let theirs = targetWorkspaceId(targetUserId);
      return mine != null && theirs != null && mine == theirs;
    }

    // Users: owner can read/write their own doc; workspace members can read profiles
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
      allow read: if isSignedIn() && inSameWorkspace(userId);
    }

    // Goals: only the owner can CRUD their own goals
    match /goals/{goalId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
    }

    // Systems: owner has full access; workspace members can read
    match /systems/{systemId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow read: if isSignedIn() && inSameWorkspace(resource.data.userId);
    }

    // Checkins: owner has full access; workspace members can read
    match /checkins/{checkinId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow read: if isSignedIn() && inSameWorkspace(resource.data.userId);
    }

    // Journal entries: only the owner can CRUD their own entries
    match /journalEntries/{entryId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
    }

    // Workspaces:
    //   read: members can read their workspace; any signed-in user may also read
    //         (required so non-members can look up a workspace by invite code before joining —
    //         the invite code itself is the security token for this flow)
    //   create: authenticated user who sets themselves as ownerId
    //   update: owner (rename, transfer, regenerate code) OR existing member (stats sync)
    //           OR a user being added via invite code join
    //   delete: owner only
    match /workspaces/{workspaceId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.memberIds
                  || isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.memberIds ||
        request.auth.uid in request.resource.data.memberIds
      );
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // Templates:
    //   public read: any visitor (isPublic == true)
    //   authenticated read: any signed-in user (premium plan check is done client-side)
    //   write: admin only
    match /templates/{templateId} {
      allow read: if resource.data.isPublic == true || isSignedIn();
      allow write: if isAdmin();
    }

    // Email leads: create-only from landing page (unauthenticated visitors allowed)
    //              read/update/delete: admin only
    match /emailLeads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Analytics events: any signed-in user may write; admin-only reads
    match /analyticsEvents/{eventId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }
  }
}
