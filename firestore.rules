rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users: only the owner can read/write their own document
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // Goals: only the owner can CRUD their own goals
    match /goals/{goalId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
    }

    // Systems: only the owner can CRUD their own systems
    match /systems/{systemId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
    }

    // Checkins: only the owner can CRUD their own checkins
    match /checkins/{checkinId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
    }

    // Journal entries: only the owner can CRUD their own entries
    match /journalEntries/{entryId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
    }
  }
}
